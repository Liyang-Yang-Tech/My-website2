<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>🎬 CINEMA PRO - 顶级电影平台</title>
  <!-- 外部依赖CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
  <!-- Tailwind自定义配置（浮夸渐变/发光/动画） -->
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            neon: {
              pink: '#ff0080', blue: '#00f0ff', purple: '#9900ff', yellow: '#ffdd00'
            },
            cinema: {
              dark: '#0a0a10', light: '#f8f9fc'
            }
          },
          fontFamily: {
            cinema: ['Inter', 'sans-serif']
          },
          animation: {
            'pulse-glow': 'pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite',
            'float': 'float 3s ease-in-out infinite',
            'spin-neon': 'spin 2s linear infinite'
          },
          keyframes: {
            pulse: { '0%, 100%': { boxShadow: '0 0 20px var(--tw-shadow-color)' }, '50%': { boxShadow: '0 0 40px var(--tw-shadow-color)' } },
            float: { '0%, 100%': { transform: 'translateY(0)' }, '50%': { transform: 'translateY(-10px)' } }
          }
        }
      }
    }
  </script>
  <!-- 自定义浮夸样式 -->
  <style type="text/tailwindcss">
    @layer utilities {
      .text-gradient {
        @apply bg-clip-text text-transparent bg-gradient-to-r from-neon-pink via-neon-blue to-neon-purple;
      }
      .neon-border {
        @apply border-2 border-transparent bg-gradient-to-r from-neon-pink to-neon-blue bg-origin-border;
      }
      .neon-shadow {
        @apply shadow-lg shadow-neon-purple/50;
      }
      .glass {
        @apply bg-white/10 backdrop-blur-xl dark:bg-black/30;
      }
      .movie-card-hover {
        @apply hover:scale-110 hover:rotate-1 hover:neon-shadow transition-all duration-300 cursor-pointer;
      }
      .scrollbar-hide {
        -ms-overflow-style: none; scrollbar-width: none;
      }
      .scrollbar-hide::-webkit-scrollbar { display: none; }
    }
    /* 全局粒子背景 */
    body {
      background: linear-gradient(135deg, #0a0a10 0%, #121222 50%, #0f0f1f 100%);
      min-height: 100vh;
      overflow-x: hidden;
    }
    .dark body {
      background: linear-gradient(135deg, #f8f9fc 0%, #e9ebf8 100%);
    }
  </style>
</head>
<body class="font-cinema text-white dark:text-cinema-dark">
  <!-- 加载动画（浮夸霓虹） -->
  <div id="loader" class="fixed inset-0 z-50 flex items-center justify-center bg-cinema-dark">
    <div class="w-20 h-20 border-4 border-neon-blue rounded-full animate-spin-neon border-t-neon-pink"></div>
  </div>

  <!-- 顶部导航（吸顶+透明渐变+浮夸） -->
  <nav id="nav" class="fixed top-0 left-0 w-full z-40 transition-all duration-500 py-3 px-4 md:px-8">
    <div class="glass rounded-full px-4 py-2 flex items-center justify-between max-w-7xl mx-auto">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-2">
        <i class="fa fa-film text-2xl text-neon-pink animate-pulse-glow"></i>
        <h1 class="text-[clamp(1.2rem,3vw,1.8rem)] font-bold text-gradient">CINEMA PRO</h1>
      </a>

      <!-- 桌面端菜单 -->
      <div class="hidden md:flex items-center gap-6">
        <a href="#" class="nav-link font-semibold hover:text-neon-blue transition-colors">首页</a>
        <a href="#hot" class="nav-link font-semibold hover:text-neon-blue transition-colors">热门</a>
        <a href="#new" class="nav-link font-semibold hover:text-neon-blue transition-colors">新片</a>
        <a href="#actor" class="nav-link font-semibold hover:text-neon-blue transition-colors">演员</a>
        <a href="#comment" class="nav-link font-semibold hover:text-neon-blue transition-colors">评论</a>
      </div>

      <!-- 功能按钮：搜索+收藏+模式+菜单 -->
      <div class="flex items-center gap-3">
        <div class="relative hidden sm:block">
          <input id="search" type="text" placeholder="搜索电影..." class="glass rounded-full px-4 py-1.5 pl-10 outline-none w-36 md:w-48 text-sm"/>
          <i class="fa fa-search absolute left-3 top-1/2 -translate-y-1/2 text-neon-blue"></i>
        </div>
        <button id="theme-toggle" class="w-9 h-9 rounded-full glass flex items-center justify-center hover:text-neon-yellow transition-colors">
          <i class="fa fa-moon-o dark:fa-sun-o"></i>
        </button>
        <button id="fav-btn" class="w-9 h-9 rounded-full glass flex items-center justify-center hover:text-neon-pink transition-colors">
          <i class="fa fa-heart-o"></i>
        </button>
        <button id="menu-btn" class="md:hidden w-9 h-9 rounded-full glass flex items-center justify-center">
          <i class="fa fa-bars"></i>
        </button>
      </div>
    </div>
  </nav>

  <!-- 移动端菜单 -->
  <div id="mobile-menu" class="fixed top-20 right-4 z-40 glass rounded-2xl p-4 w-48 hidden">
    <div class="flex flex-col gap-3">
      <a href="#" class="p-2 hover:bg-white/10 rounded-lg">首页</a>
      <a href="#hot" class="p-2 hover:bg-white/10 rounded-lg">热门电影</a>
      <a href="#new" class="p-2 hover:bg-white/10 rounded-lg">新片速递</a>
      <a href="#actor" class="p-2 hover:bg-white/10 rounded-lg">演员专区</a>
    </div>
  </div>

  <!-- 英雄区轮播（全屏+浮夸视觉） -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="swiper hero-swiper absolute inset-0">
      <div class="swiper-wrapper">
        <!-- 轮播1 -->
        <div class="swiper-slide relative">
          <img src="https://picsum.photos/id/237/1920/1080" class="w-full h-full object-cover opacity-60"/>
          <div class="absolute inset-0 bg-gradient-to-t from-cinema-dark to-transparent"></div>
          <div class="absolute bottom-1/4 left-4 md:left-16 max-w-xl">
            <h2 class="text-[clamp(2rem,5vw,4rem)] font-bold text-gradient leading-tight mb-4">星际穿越</h2>
            <p class="text-lg md:text-xl mb-6 text-gray-200">豆瓣9.4 | 科幻神作 | 宇宙终极浪漫</p>
            <div class="flex gap-4">
              <button class="neon-border px-6 py-2 rounded-full font-bold bg-neon-purple/20 hover:bg-neon-purple/40 transition-colors animate-pulse-glow">
                <i class="fa fa-play mr-2"></i>立即播放
              </button>
              <button class="glass px-6 py-2 rounded-full font-bold hover:bg-white/20 transition-colors">
                <i class="fa fa-plus mr-2"></i>加入收藏
              </button>
            </div>
          </div>
        </div>
        <!-- 轮播2 -->
        <div class="swiper-slide relative">
          <img src="https://picsum.photos/id/1/1920/1080" class="w-full h-full object-cover opacity-60"/>
          <div class="absolute inset-0 bg-gradient-to-t from-cinema-dark to-transparent"></div>
          <div class="absolute bottom-1/4 left-4 md:left-16 max-w-xl">
            <h2 class="text-[clamp(2rem,5vw,4rem)] font-bold text-gradient leading-tight mb-4">盗梦空间</h2>
            <p class="text-lg md:text-xl mb-6 text-gray-200">豆瓣9.3 | 悬疑烧脑 | 多层梦境</p>
            <div class="flex gap-4">
              <button class="neon-border px-6 py-2 rounded-full font-bold bg-neon-blue/20 hover:bg-neon-blue/40 transition-colors animate-pulse-glow">
                <i class="fa fa-play mr-2"></i>立即播放
              </button>
              <button class="glass px-6 py-2 rounded-full font-bold hover:bg-white/20 transition-colors">
                <i class="fa fa-plus mr-2"></i>加入收藏
              </button>
            </div>
          </div>
        </div>
      </div>
      <!-- 轮播指示器（霓虹） -->
      <div class="swiper-pagination !bottom-10"></div>
    </div>
  </section>

  <!-- 分类筛选栏（功能拉满） -->
  <section class="max-w-7xl mx-auto px-4 py-8">
    <div class="glass rounded-2xl p-4 flex flex-wrap gap-3 items-center justify-center">
      <button class="px-4 py-2 rounded-full bg-neon-pink/30 font-bold">全部</button>
      <button class="px-4 py-2 rounded-full glass hover:bg-white/10">动作</button>
      <button class="px-4 py-2 rounded-full glass hover:bg-white/10">科幻</button>
      <button class="px-4 py-2 rounded-full glass hover:bg-white/10">喜剧</button>
      <button class="px-4 py-2 rounded-full glass hover:bg-white/10">悬疑</button>
      <button class="px-4 py-2 rounded-full glass hover:bg-white/10">动画</button>
      <button class="px-4 py-2 rounded-full glass hover:bg-white/10">高分</button>
      <button class="px-4 py-2 rounded-full glass hover:bg-white/10">2026</button>
    </div>
  </section>

  <!-- 热门电影榜单（功能+浮夸卡片） -->
  <section id="hot" class="max-w-7xl mx-auto px-4 py-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-[clamp(1.5rem,4vw,2.5rem)] font-bold text-gradient">🔥 热门票房榜</h2>
      <a href="#" class="text-neon-blue hover:underline">查看更多 <i class="fa fa-angle-right"></i></a>
    </div>
    <!-- 横向滑动卡片 -->
    <div class="overflow-x-auto scrollbar-hide pb-4">
      <div class="flex gap-6 w-max">
        <!-- 电影卡片1 -->
        <div class="movie-card-hover w-64 rounded-2xl overflow-hidden glass">
          <img src="https://picsum.photos/id/111/400/500" class="w-full h-80 object-cover"/>
          <div class="p-4">
            <h3 class="font-bold text-lg mb-1">沙丘2</h3>
            <div class="flex items-center gap-2 text-yellow-400 mb-2">
              <i class="fa fa-star"></i><span>9.2</span>
            </div>
            <span class="text-xs px-2 py-1 rounded-full bg-neon-purple/30">科幻</span>
          </div>
        </div>
        <!-- 电影卡片2 -->
        <div class="movie-card-hover w-64 rounded-2xl overflow-hidden glass">
          <img src="https://picsum.photos/id/112/400/500" class="w-full h-80 object-cover"/>
          <div class="p-4">
            <h3 class="font-bold text-lg mb-1">哥斯拉大战金刚</h3>
            <div class="flex items-center gap-2 text-yellow-400 mb-2">
              <i class="fa fa-star"></i><span>8.5</span>
            </div>
            <span class="text-xs px-2 py-1 rounded-full bg-neon-blue/30">动作</span>
          </div>
        </div>
        <!-- 卡片3-6（省略重复，直接运行） -->
        <div class="movie-card-hover w-64 rounded-2xl overflow-hidden glass"><img src="https://picsum.photos/id/113/400/500" class="w-full h-80 object-cover"/><div class="p-4"><h3 class="font-bold text-lg mb-1">疯狂动物城2</h3><div class="flex items-center gap-2 text-yellow-400 mb-2"><i class="fa fa-star"></i><span>9.0</span></div><span class="text-xs px-2 py-1 rounded-full bg-neon-green/30">动画</span></div></div>
        <div class="movie-card-hover w-64 rounded-2xl overflow-hidden glass"><img src="https://picsum.photos/id/114/400/500" class="w-full h-80 object-cover"/><div class="p-4"><h3 class="font-bold text-lg mb-1">无声秘境</h3><div class="flex items-center gap-2 text-yellow-400 mb-2"><i class="fa fa-star"></i><span>8.8</span></div><span class="text-xs px-2 py-1 rounded-full bg-neon-pink/30">悬疑</span></div></div>
        <div class="movie-card-hover w-64 rounded-2xl overflow-hidden glass"><img src="https://picsum.photos/id/115/400/500" class="w-full h-80 object-cover"/><div class="p-4"><h3 class="font-bold text-lg mb-1">极速追击</h3><div class="flex items-center gap-2 text-yellow-400 mb-2"><i class="fa fa-star"></i><span>8.3</span></div><span class="text-xs px-2 py-1 rounded-full bg-neon-yellow/30">动作</span></div></div>
      </div>
    </div>
  </section>

  <!-- 新片速递 -->
  <section id="new" class="max-w-7xl mx-auto px-4 py-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-[clamp(1.5rem,4vw,2.5rem)] font-bold text-gradient">🎬 2026新片速递</h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      <!-- 极简卡片 -->
      <div class="movie-card-hover rounded-xl overflow-hidden glass"><img src="https://picsum.photos/id/121/300/400" class="w-full h-48 object-cover"/><div class="p-2"><h3 class="font-bold text-sm">未来战警</h3><p class="text-xs text-gray-300">2026</p></div></div>
      <div class="movie-card-hover rounded-xl overflow-hidden glass"><img src="https://picsum.photos/id/122/300/400" class="w-full h-48 object-cover"/><div class="p-2"><h3 class="font-bold text-sm">暗夜行者</h3><p class="text-xs text-gray-300">2026</p></div></div>
      <div class="movie-card-hover rounded-xl overflow-hidden glass"><img src="https://picsum.photos/id/123/300/400" class="w-full h-48 object-cover"/><div class="p-2"><h3 class="font-bold text-sm">银河护卫</h3><p class="text-xs text-gray-300">2026</p></div></div>
      <div class="movie-card-hover rounded-xl overflow-hidden glass"><img src="https://picsum.photos/id/124/300/400" class="w-full h-48 object-cover"/><div class="p-2"><h3 class="font-bold text-sm">甜心大冒险</h3><p class="text-xs text-gray-300">2026</p></div></div>
      <div class="movie-card-hover rounded-xl overflow-hidden glass"><img src="https://picsum.photos/id/125/300/400" class="w-full h-48 object-cover"/><div class="p-2"><h3 class="font-bold text-sm">致命游戏</h3><p class="text-xs text-gray-300">2026</p></div></div>
    </div>
  </section>

  <!-- 演员专区 -->
  <section id="actor" class="max-w-7xl mx-auto px-4 py-12">
    <h2 class="text-[clamp(1.5rem,4vw,2.5rem)] font-bold text-gradient mb-8">🌟 热门演员</h2>
    <div class="flex gap-6 overflow-x-auto scrollbar-hide pb-4">
      <div class="w-32 text-center animate-float"><img src="https://picsum.photos/id/64/200/200" class="w-24 h-24 rounded-full object-cover border-2 border-neon-blue mx-auto mb-2"/><h3 class="font-bold">提莫西·查拉梅</h3></div>
      <div class="w-32 text-center animate-float"><img src="https://picsum.photos/id/65/200/200" class="w-24 h-24 rounded-full object-cover border-2 border-neon-pink mx-auto mb-2"/><h3 class="font-bold">赞达亚</h3></div>
      <div class="w-32 text-center animate-float"><img src="https://picsum.photos/id/66/200/200" class="w-24 h-24 rounded-full object-cover border-2 border-neon-purple mx-auto mb-2"/><h3 class="font-bold">汤姆·赫兰德</h3></div>
    </div>
  </section>

  <!-- 评论区 -->
  <section id="comment" class="max-w-7xl mx-auto px-4 py-12 mb-20">
    <h2 class="text-[clamp(1.5rem,4vw,2.5rem)] font-bold text-gradient mb-8">💬 热门口碑评论</h2>
    <div class="glass rounded-2xl p-6 space-y-4">
      <div class="border-b border-white/10 pb-3"><div class="flex items-center gap-2 mb-1"><img src="https://picsum.photos/id/1001/50/50" class="w-8 h-8 rounded-full"/><h4 class="font-bold">电影发烧友</h4><div class="text-yellow-400 text-xs"><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i></div></div><p class="text-sm text-gray-300">沙丘2的视觉效果直接拉满，史诗级配乐，年度最佳科幻片！</p></div>
      <div class="border-b border-white/10 pb-3"><div class="flex items-center gap-2 mb-1"><img src="https://picsum.photos/id/1002/50/50" class="w-8 h-8 rounded-full"/><h4 class="font-bold">影评人</h4><div class="text-yellow-400 text-xs"><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i></div></div><p class="text-sm text-gray-300">剧情紧凑，特效炸裂，非常值得二刷！</p></div>
    </div>
  </section>

  <!-- 电影详情弹窗（毛玻璃+霓虹） -->
  <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-md" id="modal-close"></div>
    <div class="glass relative rounded-3xl neon-border max-w-2xl w-full max-h-[90vh] overflow-y-auto">
      <button id="modal-close-btn" class="absolute top-4 right-4 w-8 h-8 rounded-full glass flex items-center justify-center z-10"><i class="fa fa-times"></i></button>
      <div class="p-6"><h2 class="text-2xl font-bold text-gradient mb-4">电影详情</h2><p class="mb-2">评分：9.2</p><p class="mb-2">类型：科幻 / 动作</p><p class="mb-4">简介：未来世界，人类为了生存踏上星际之旅...</p><button class="neon-border px-6 py-2 rounded-full font-bold bg-neon-purple/20 w-full"><i class="fa fa-play mr-2"></i>立即播放</button></div>
    </div>
  </div>

  <script>
    // 加载动画
    window.addEventListener('load', () => {
      setTimeout(() => document.getElementById('loader').classList.add('opacity-0', 'hidden'), 1000);
    });

    // 导航滚动效果
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('nav');
      nav.classList.toggle('py-1', window.scrollY > 50);
      nav.classList.toggle('bg-black/30', window.scrollY > 50);
    });

    // 暗黑模式切换
    const themeToggle = document.getElementById('theme-toggle');
    themeToggle.addEventListener('click', () => document.documentElement.classList.toggle('dark'));

    // 移动端菜单
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));

    // 轮播初始化
    new Swiper('.hero-swiper', {
      loop: true, autoplay: { delay: 5000, disableOnInteraction: false },
      pagination: { el: '.swiper-pagination', clickable: true },
      effect: 'fade', fadeEffect: { crossFade: true }
    });

    // 弹窗功能
    const modal = document.getElementById('modal');
    const movieCards = document.querySelectorAll('.movie-card-hover');
    const closeModal = () => modal.classList.add('hidden');
    movieCards.forEach(card => card.addEventListener('click', () => modal.classList.remove('hidden')));
    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('modal-close-btn').addEventListener('click', closeModal);

    // 搜索功能
    const search = document.getElementById('search');
    search.addEventListener('input', (e) => console.log('搜索：', e.target.value));
  </script>
</body>
</html>